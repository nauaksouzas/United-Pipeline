# Database (SQLite path is relative to the prisma/ directory for local development)
DATABASE_URL="file:./dev.db"

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET="REPLACE_WITH_RANDOM_HEX_64"

# Environment
NODE_ENV="development"

# Firebase frontend config (Vite exposes only VITE_* variables to the browser)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""

# EchoTrack production Firebase values for Vercel, if you are deploying this app:
# VITE_FIREBASE_API_KEY="AIzaSyCKk93ppGh_P-M_EtUf5ZeePkPROMchAqw"
# VITE_FIREBASE_AUTH_DOMAIN="echotrack-db76d.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID="echotrack-db76d"
# VITE_FIREBASE_STORAGE_BUCKET="echotrack-db76d.firebasestorage.app"
# VITE_FIREBASE_MESSAGING_SENDER_ID="735065066993"
# VITE_FIREBASE_APP_ID="1:735065066993:web:35e9fb6944a933707b4850"
# VITE_FIREBASE_MEASUREMENT_ID="G-1CNBXL0XCS"
# VITE_FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-752137eb-d681-460e-b35c-eb81a0cd6303"

# Firebase Admin backend config
FIREBASE_PROJECT_ID=""
FIREBASE_SERVICE_ACCOUNT_BASE64=""
GOOGLE_APPLICATION_CREDENTIALS=""

# Vercel deployment:
# Set the same variables above in Vercel Project Settings → Environment Variables.
# Prefer FIREBASE_SERVICE_ACCOUNT_BASE64 for Firebase Admin credentials and never
# commit service account JSON files or private keys.
